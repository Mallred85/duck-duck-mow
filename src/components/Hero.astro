---
import { PHONE_DISPLAY, PHONE_HREF } from '@/config/site';

const LAWN_STRIPES = "https://d2xsxph8kpxj0f.cloudfront.net/310519663369857976/gh22GidGuqNYiudTF7cxqY/lawn-stripes_39dc45aa.jpg";
const DUCK_LOGO    = "https://d2xsxph8kpxj0f.cloudfront.net/310519663369857976/gh22GidGuqNYiudTF7cxqY/duck-mower-logo_90c36037.png";
---

<section class="relative min-h-screen flex items-center pt-20 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <img
      src={LAWN_STRIPES}
      alt="Beautiful striped lawn"
      class="absolute inset-0 w-full h-full object-cover"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[#0a2e1a]/95 via-[#0a2e1a]/85 to-[#0a2e1a]/60"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#0a2e1a]/40 to-transparent"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Left: copy -->
      <div class="fade-in-left">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full border border-white/20 mb-6">
          <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <span class="text-sm text-white/90 font-medium">Family-Owned &bull; 5 Years of Service</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-white leading-tight mb-6 font-display">
          Your Lawn,{' '}
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-300 to-emerald-400">
            Our Passion
          </span>
        </h1>

        <p class="text-lg sm:text-xl text-white/80 mb-8 max-w-lg leading-relaxed">
          Professional lawn care by brothers who take pride in every yard.
          Serving Herriman, Riverton, South Jordan, and Bluffdale.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-10">
          <a
            href="#contact"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-green-500 to-emerald-600 text-white font-bold rounded-full hover:from-green-400 hover:to-emerald-500 transition-all shadow-2xl shadow-green-500/30 hover:shadow-green-500/50 hover:scale-105 text-lg"
          >
            Get a Free Quote
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href={PHONE_HREF}
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/10 backdrop-blur-sm text-white font-bold rounded-full border-2 border-white/30 hover:bg-white/20 transition-all text-lg"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 8V5z"
              />
            </svg>
            {PHONE_DISPLAY}
          </a>
        </div>

        <!-- Trust badges -->
        <div class="flex flex-wrap gap-6">
          {[
            { label: 'Insured',    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
            { label: 'Reliable',   icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
            { label: 'Family-Run', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' },
          ].map(({ label, icon }) => (
            <div class="flex items-center gap-2 text-white/70">
              <svg class="w-5 h-5 text-green-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon} />
              </svg>
              <span class="text-sm font-medium">{label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: card -->
      <div class="hidden lg:flex justify-center fade-in-right">
        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-r from-green-400/20 to-emerald-400/20 rounded-3xl blur-2xl"></div>
          <div class="relative bg-white/95 backdrop-blur-sm rounded-3xl p-8 shadow-2xl max-w-md w-full border border-white/50">
            <div class="text-center">
              <img src={DUCK_LOGO} alt="Duck Duck Mow" class="h-32 w-auto mx-auto mb-6" width="128" height="128" />
              <h2 class="text-3xl font-extrabold text-green-800 mb-1 font-display">Duck Duck Mow</h2>
              <p class="text-gray-500 font-medium mb-6">Neighborhood Lawn Service</p>

              <div class="bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl p-6 border border-green-100">
                <p class="text-sm text-gray-400 mb-1">Call or Text Anytime</p>
                <a href={PHONE_HREF} class="text-3xl font-extrabold text-green-800 hover:text-green-700 transition-colors">
                  {PHONE_DISPLAY}
                </a>
                <p class="text-sm text-green-800 font-semibold mt-2">Free Quotes</p>
              </div>

              <div class="mt-6 flex justify-center gap-1">
                {[1,2,3,4,5].map((i) => (
                  <svg key={i} class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="text-sm text-gray-400 mt-1">Trusted by our neighbors</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-16 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <svg class="w-8 h-8 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </div>

  <!-- Rounded wave transition -->
  <div class="absolute bottom-0 left-0 right-0 z-20">
    <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full block">
      <path d="M0,80 L0,55 Q720,0 1440,55 L1440,80 Z" fill="white"/>
    </svg>
  </div>
</section>
