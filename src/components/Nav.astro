---
/**
 * Nav.astro
 * Sticky navigation with mobile hamburger menu (vanilla JS, no React).
 */
import { PHONE_DISPLAY, PHONE_HREF } from '@/config/site';

interface Props {
  /** Highlight the current page link */
  currentPage?: 'home' | 'pricing' | 'blog';
}

const { currentPage } = Astro.props;

const navLinks = [
  { href: '/#services',  label: 'Services',  page: 'home' },
  { href: '/#areas',     label: 'Areas',     page: 'home' },
  { href: '/#reviews',   label: 'Reviews',   page: 'home' },
  { href: '/pricing',    label: 'Pricing',   page: 'pricing' },
  { href: '/blog',       label: 'Blog',      page: 'blog' },
  { href: '/#faq',       label: 'FAQ',       page: 'home' },
];
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-green-600/10 shadow-sm"
>
  <div class="container mx-auto px-4 flex items-center justify-between h-16 lg:h-20">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3">
      <img
        src="https://d2xsxph8kpxj0f.cloudfront.net/310519663369857976/gh22GidGuqNYiudTF7cxqY/duck-mower-logo_90c36037.png"
        alt="Duck Duck Mow"
        class="h-10 lg:h-14 w-auto"
        width="56"
        height="56"
      />
      <span class="hidden sm:block text-xl lg:text-2xl font-extrabold text-green-800 tracking-tight">
        Duck Duck Mow
      </span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      {navLinks.map(({ href, label, page }) => (
        <a
          href={href}
          class={`text-sm font-medium transition-colors hover:text-green-800 ${
            currentPage === page && page !== 'home'
              ? 'text-green-800 font-semibold'
              : 'text-gray-600'
          }`}
        >
          {label}
        </a>
      ))}
      <a
        href={PHONE_HREF}
        class="flex items-center gap-1.5 text-sm font-bold text-green-800"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 8V5z"
          />
        </svg>
        {PHONE_DISPLAY}
      </a>
      <a
        href="/#contact"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-green-800 text-white font-semibold rounded-full hover:bg-green-900 transition-all shadow-lg shadow-green-600/25 hover:scale-105 text-sm"
      >
        Free Quote
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

    <!-- Mobile: phone + hamburger -->
    <div class="flex md:hidden items-center gap-3">
      <a href={PHONE_HREF} class="flex items-center gap-1 text-sm font-bold text-green-800">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 8V5z"
          />
        </svg>
        Call
      </a>
      <button
        id="mobile-menu-btn"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        class="p-2 rounded-lg hover:bg-gray-100"
      >
        <svg id="icon-open"  class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-white border-t border-gray-100"
  >
    <div class="container mx-auto px-4 py-4 flex flex-col gap-2">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class="mobile-menu-link py-2 text-sm font-medium text-gray-700 hover:text-green-800 transition-colors"
        >
          {label}
        </a>
      ))}
      <a
        href="/#contact"
        class="mobile-menu-link mt-2 inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-green-800 text-white font-semibold rounded-full"
      >
        Get Free Quote
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</nav>

<script>
  const btn   = document.getElementById('mobile-menu-btn')!;
  const menu  = document.getElementById('mobile-menu')!;
  const open  = document.getElementById('icon-open')!;
  const close = document.getElementById('icon-close')!;

  function toggleMenu(force?: boolean) {
    const isOpen = force ?? menu.classList.contains('hidden');
    menu.classList.toggle('hidden', !isOpen);
    open.classList.toggle('hidden', isOpen);
    close.classList.toggle('hidden', !isOpen);
    btn.setAttribute('aria-expanded', String(isOpen));
  }

  btn.addEventListener('click', () => toggleMenu());

  // Close on any link click
  document.querySelectorAll('.mobile-menu-link').forEach((link) => {
    link.addEventListener('click', () => toggleMenu(false));
  });
</script>
