---
/**
 * Reviews.astro
 *
 * Fetches reviews from Sanity at build time.
 * Falls back to static data if Sanity returns nothing
 * (useful during initial setup before adding reviews to Sanity).
 *
 * To add reviews: log in to sanity.io > your Duck Duck Mow project
 * > Studio > Reviews > New Review. Mark "Featured" to show on homepage.
 */
import { getFeaturedReviews, type SanityReview } from '@/lib/sanity';

// Static fallback reviews (same as current site)
const fallbackReviews: SanityReview[] = [
  { _id: '1', clientName: 'Sarah M.', neighborhood: 'Herriman', rating: 5, reviewText: 'These boys do an amazing job every single week. Our lawn has never looked better! So reliable and professional for their age. Highly recommend to all our neighbors.', serviceType: 'Lawn Mowing', featured: true },
  { _id: '2', clientName: 'David R.', neighborhood: 'Riverton', rating: 5, reviewText: "We've used Duck Duck Mow for two seasons now. They show up on time, do great work, and the price is very fair. Love supporting a local family business!", serviceType: 'Lawn Mowing', featured: true },
  { _id: '3', clientName: 'Jennifer L.', neighborhood: 'South Jordan', rating: 5, reviewText: 'The fall cleanup they did was incredible. Every leaf gone, yard looking pristine. These young men are hard workers and very respectful. Will definitely use them again.', serviceType: 'Seasonal Cleanup', featured: true },
  { _id: '4', clientName: 'Mike T.', neighborhood: 'Bluffdale', rating: 5, reviewText: 'Best lawn service in the area. The edging is always perfect and they blow off all the sidewalks and driveway. Great attention to detail!', serviceType: 'Edging', featured: true },
  { _id: '5', clientName: 'Karen W.', neighborhood: 'Herriman', rating: 5, reviewText: 'So happy we found Duck Duck Mow! As a busy family, having reliable lawn care is a lifesaver. The boys are polite, punctual, and do fantastic work.', serviceType: 'Lawn Mowing', featured: true },
  { _id: '6', clientName: 'Tom B.', neighborhood: 'South Jordan', rating: 5, reviewText: "I've tried several lawn services over the years and Duck Duck Mow is by far the best. Family-owned businesses just care more. You can tell these guys take pride in their work.", serviceType: 'Lawn Mowing', featured: true },
];

let reviews: SanityReview[] = [];
try {
  reviews = await getFeaturedReviews();
} catch {
  // Sanity not configured yet — use fallback
}

if (reviews.length === 0) {
  reviews = fallbackReviews;
}
---

<section id="reviews" class="py-20 sm:py-28 relative overflow-hidden" style="background-color: #16a34a;">
  <!-- Sunbeam rays -->
  <div class="absolute inset-0 pointer-events-none" style="background-image: repeating-conic-gradient(from 0deg at 50% -10%, rgba(255,255,255,0.05) 0deg 9deg, transparent 9deg 18deg);"></div>
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 50% 0%, rgba(255,255,255,0.1) 0%, transparent 65%);"></div>

  <div class="relative z-10 container mx-auto px-4">
    <div class="text-center mb-16 fade-in">
      <span class="inline-block px-4 py-1.5 bg-white/20 text-white text-sm font-semibold rounded-full mb-4">
        What Neighbors Say
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4 font-display">
        Trusted by Your Neighbors
      </h2>
      <p class="text-lg text-white/70 max-w-xl mx-auto">
        Real reviews from real homeowners in Herriman, Riverton, South Jordan & Bluffdale.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {reviews.map((review) => (
        <div class="fade-in bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/20 hover:bg-white/15 transition-colors">
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {Array.from({ length: review.rating }).map((_, i) => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Review text -->
          <p class="text-white/90 leading-relaxed mb-6 text-sm">&ldquo;{review.reviewText}&rdquo;</p>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
              <span class="text-white font-bold text-sm">{review.clientName.charAt(0)}</span>
            </div>
            <div>
              <p class="font-bold text-white text-sm">{review.clientName}</p>
              <p class="text-white/60 text-xs">{review.neighborhood}{review.serviceType ? ` · ${review.serviceType}` : ''}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
