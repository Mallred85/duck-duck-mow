---
const BEAUTIFUL_LAWN = "https://d2xsxph8kpxj0f.cloudfront.net/310519663369857976/gh22GidGuqNYiudTF7cxqY/beautiful-lawn_089b2364.jpg";

const values = [
  { label: 'Consistency', desc: 'Same brothers, same day, every week — you\'ll always know who\'s showing up.' },
  { label: 'Detail-Oriented', desc: 'We edge, trim, and blow every single visit. A great mow isn\'t done until the driveway is clean.' },
  { label: 'Fair Prices', desc: 'Starting at $35/visit with no hidden fees. We quote honestly and stick to it.' },
];
---

<section id="about" class="py-20 sm:py-28 bg-gradient-to-br from-green-50/50 via-white to-emerald-50/30">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Image -->
      <div class="fade-in">
        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-r from-green-600/10 to-emerald-400/10 rounded-3xl blur-xl"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-2xl">
            <img
              src={BEAUTIFUL_LAWN}
              alt="Beautiful lawn maintained by Duck Duck Mow"
              class="w-full h-80 lg:h-[28rem] object-cover"
              loading="lazy"
              width="600"
              height="448"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <div class="flex items-center gap-3 bg-white/90 backdrop-blur-sm rounded-xl px-5 py-3">
                <div class="w-12 h-12 rounded-full bg-green-600 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                  </svg>
                </div>
                <div>
                  <p class="font-bold text-gray-900 text-sm">Family-Owned Business</p>
                  <p class="text-xs text-gray-500">Brothers working together since 2020</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Copy -->
      <div class="fade-in">
        <span class="inline-block px-4 py-1.5 bg-green-50 text-green-600 text-sm font-semibold rounded-full mb-4">
          Our Story
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-gray-900 mb-6 font-display leading-tight">
          Neighbors Caring for <span class="text-green-600">Neighbors' Lawns</span>
        </h2>
        <p class="text-lg text-gray-500 leading-relaxed mb-6">
          We're brothers who grew up in this community and started mowing lawns because we
          genuinely love the work — and the results. Since 2020 we've been building a reputation
          for showing up on time, doing excellent work, and treating every yard like it's our own.
        </p>
        <p class="text-gray-500 leading-relaxed mb-8">
          We're not a big corporation. We're your neighbors. And that means we care about the
          quality of our work in a way that only a family business can.
        </p>

        <div class="space-y-4">
          {values.map(({ label, desc }) => (
            <div class="flex gap-4">
              <div class="w-8 h-8 rounded-lg bg-green-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <p class="font-bold text-gray-900 text-sm">{label}</p>
                <p class="text-gray-500 text-sm leading-relaxed">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
