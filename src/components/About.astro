---
const BEAUTIFUL_LAWN = "https://d2xsxph8kpxj0f.cloudfront.net/310519663369857976/gh22GidGuqNYiudTF7cxqY/beautiful-lawn_089b2364.jpg";

const stats = [
  { value: '5+', label: 'Years' },
  { value: '4',  label: 'Cities' },
  { value: '100%', label: 'Family-Run' },
];

const values = [
  { label: 'Consistency', desc: 'Same brothers, same day, every week. You\'ll always know who\'s showing up.' },
  { label: 'Detail-Oriented', desc: 'We edge, trim, and blow every single visit. A great mow isn\'t done until the driveway is clean.' },
  { label: 'Fair Prices', desc: 'Starting at $35/visit with no hidden fees. We quote honestly and stick to it.' },
];
---

<section id="about" class="py-20 sm:py-28 bg-gradient-to-br from-green-50/50 via-white to-emerald-50/30">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Image -->
      <div class="fade-in">
        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-r from-green-600/10 to-emerald-400/10 rounded-3xl blur-xl"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-2xl">
            <img
              src={BEAUTIFUL_LAWN}
              alt="Beautiful lawn maintained by Duck Duck Mow"
              class="w-full h-80 lg:h-[28rem] object-cover"
              loading="lazy"
              width="600"
              height="448"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <div class="flex items-center gap-3 bg-white/90 backdrop-blur-sm rounded-xl px-5 py-3">
                <div class="w-12 h-12 rounded-full bg-green-600 flex items-center justify-center flex-shrink-0">
                  <!-- Family / two-person icon -->
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197"/>
                  </svg>
                </div>
                <div>
                  <p class="font-bold text-gray-900 text-sm">Family-Owned Business</p>
                  <p class="text-xs text-gray-500">Brothers working together since 2020</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Copy -->
      <div class="fade-in">
        <span class="inline-block px-4 py-1.5 bg-green-50 text-green-600 text-sm font-semibold rounded-full mb-4">
          Our Story
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-gray-900 mb-6 font-display leading-tight">
          Brothers on a <span class="text-green-600">Mission</span>
        </h2>
        <p class="text-lg text-gray-500 leading-relaxed mb-4">
          Duck Duck Mow started as a simple idea between brothers: take care of our neighbors'
          lawns the way we'd want ours taken care of. Five years later, that idea has grown into
          a trusted local business.
        </p>
        <p class="text-gray-500 leading-relaxed mb-6">
          We're not a big corporation. We're your neighbors. We show up on time, do the job
          right, and treat every yard like it's our own.
        </p>

        <!-- Stats row -->
        <div class="grid grid-cols-3 gap-4 mb-8">
          {stats.map(({ value, label }) => (
            <div class="text-center border border-gray-200 rounded-xl py-4">
              <p class="text-2xl font-extrabold text-green-600">{value}</p>
              <p class="text-sm text-gray-500 mt-0.5">{label}</p>
            </div>
          ))}
        </div>

        <!-- Values -->
        <div class="space-y-4 mb-8">
          {values.map(({ label, desc }) => (
            <div class="flex gap-4">
              <div class="w-8 h-8 rounded-lg bg-green-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <p class="font-bold text-gray-900 text-sm">{label}</p>
                <p class="text-gray-500 text-sm leading-relaxed">{desc}</p>
              </div>
            </div>
          ))}
        </div>

        <a href="#quote" class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-3 rounded-full transition-colors">
          Get Your Free Quote
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>
