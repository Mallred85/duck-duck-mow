---
import { PHONE_DISPLAY, PHONE_HREF, EMAIL } from '@/config/site';
---

<footer class="bg-[#0a2e1a] text-white py-12">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img
            src="https://d2xsxph8kpxj0f.cloudfront.net/310519663369857976/gh22GidGuqNYiudTF7cxqY/duck-mower-logo_90c36037.png"
            alt="Duck Duck Mow"
            class="h-12 w-auto"
            width="48"
            height="48"
          />
          <span class="font-extrabold text-lg">Duck Duck Mow</span>
        </div>
        <p class="text-white/60 text-sm leading-relaxed">
          Family-owned lawn care serving Herriman, Riverton, South Jordan & Bluffdale.
          Brothers who take pride in every yard.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <p class="font-semibold text-white/80 mb-3 text-sm uppercase tracking-wider">Quick Links</p>
        <ul class="space-y-2 text-sm text-white/60">
          <li><a href="/#services" class="hover:text-white transition-colors">Services</a></li>
          <li><a href="/pricing"   class="hover:text-white transition-colors">Pricing</a></li>
          <li><a href="/blog"      class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="/#faq"      class="hover:text-white transition-colors">FAQ</a></li>
          <li><a href="/#contact"  class="hover:text-white transition-colors">Get a Free Quote</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="font-semibold text-white/80 mb-3 text-sm uppercase tracking-wider">Contact</p>
        <ul class="space-y-2 text-sm text-white/60">
          <li>
            <a href={PHONE_HREF} class="hover:text-white transition-colors flex items-center gap-2">
              <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 8V5z"
                />
              </svg>
              {PHONE_DISPLAY}
            </a>
          </li>
          <li>
            <a href={`mailto:${EMAIL}`} class="hover:text-white transition-colors flex items-center gap-2">
              <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                />
              </svg>
              {EMAIL}
            </a>
          </li>
          <li class="text-white/40 mt-2">
            Herriman · Riverton · South Jordan · Bluffdale
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-white/40 text-sm">&copy; {new Date().getFullYear()} Duck Duck Mow. Family-owned in Utah.</p>
      <p class="text-white/30 text-xs">Serving Herriman, Riverton, South Jordan & Bluffdale</p>
    </div>
  </div>
</footer>
