---
const areas = [
  {
    city: 'Herriman',
    desc: 'Our home base. We know every neighborhood and serve the full city.',
    zip: '84096',
  },
  {
    city: 'Riverton',
    desc: 'Full coverage throughout Riverton, including Mountain View Corridor neighborhoods.',
    zip: '84065',
  },
  {
    city: 'South Jordan',
    desc: 'Serving South Jordan homeowners from Daybreak to The Crossing and everywhere in between.',
    zip: '84009',
  },
  {
    city: 'Bluffdale',
    desc: 'Including the Bluffdale city center and surrounding residential areas.',
    zip: '84065',
  },
];
---

<section id="areas" class="py-20 sm:py-28 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16 fade-in">
      <span class="inline-block px-4 py-1.5 bg-green-50 text-green-600 text-sm font-semibold rounded-full mb-4">
        Where We Work
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-gray-900 mb-4 font-display">
        Serving <span class="text-green-600">Your Community</span>
      </h2>
      <p class="text-lg text-gray-500 max-w-xl mx-auto">
        We focus on four communities in the Salt Lake Valley so we can give every lawn the attention it deserves.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {areas.map(({ city, desc, zip }) => (
        <div class="fade-in group text-center p-8 rounded-2xl border border-gray-100 hover:border-green-200 hover:shadow-lg hover:shadow-green-500/5 transition-all">
          <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-green-50 flex items-center justify-center group-hover:bg-green-100 transition-colors">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-extrabold text-gray-900 mb-2">{city}</h3>
          <p class="text-xs text-green-600 font-semibold mb-3">{city}, UT {zip}</p>
          <p class="text-gray-500 text-sm leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-12 fade-in">
      <p class="text-gray-500 text-sm">
        Not sure if we serve your neighborhood?{' '}
        <a href="#contact" class="text-green-600 font-semibold hover:underline">
          Send us a message
        </a>{' '}
        and we'll let you know right away.
      </p>
    </div>
  </div>
</section>
