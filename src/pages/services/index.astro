---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import { PHONE_DISPLAY, PHONE_HREF, site } from '@/config/site';

const services = [
  {
    title: 'Lawn Mowing',
    slug: 'lawn-mowing',
    desc: 'Weekly and bi-monthly mowing for Herriman, Riverton, South Jordan & Bluffdale. Clean, even cuts every visit.',
    icon: 'M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4',
  },
  {
    title: 'Edging',
    slug: 'edging',
    desc: 'Crisp, defined edges along every driveway, sidewalk, and landscape bed - included on every visit.',
    icon: 'M4 6h16M4 12h16M4 18h7',
  },
  {
    title: 'Trimming',
    slug: 'trimming',
    desc: 'Detail trimming around fences, posts, sprinkler heads, and anywhere the mower can\'t reach.',
    icon: 'M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z',
  },
  {
    title: 'Lawn Blowing',
    slug: 'lawn-blowing',
    desc: 'Every hard surface blown clean at the end of every visit. Driveways, sidewalks, patios - no clippings left behind.',
    icon: 'M5 3l14 9-14 9V3z',
  },
  {
    title: 'Seasonal Cleanup',
    slug: 'seasonal-cleanup',
    desc: 'Spring and fall cleanups including leaf removal, debris clearing, and full-yard detail work. Custom quotes.',
    icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3',
  },
];
---

<BaseLayout
  title="Lawn Care Services | Duck Duck Mow | Herriman, Riverton, South Jordan & Bluffdale"
  noSuffix
  description="Professional lawn mowing, edging, trimming, blowing, and seasonal cleanup in Herriman, Riverton, South Jordan, and Bluffdale, Utah. Full-service lawn care, every visit."
  keywords="lawn care services Utah, lawn mowing edging trimming, seasonal cleanup Utah, South Salt Lake County lawn service"
  breadcrumbs={[
    { name: 'Home', url: site.url },
    { name: 'Services', url: `${site.url}/services` },
  ]}
>
  <Nav />
  <main class="pt-16 lg:pt-20">

    <section class="relative pt-16 pb-20 sm:pt-24 sm:pb-28 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-green-50/80 via-white to-emerald-50/40"></div>
      <div class="container mx-auto px-4 relative z-10 text-center max-w-3xl fade-in">
        <span class="inline-block px-4 py-1.5 bg-green-50 text-green-800 text-sm font-semibold rounded-full mb-4">
          What We Do
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 mb-6 leading-tight font-display">
          Lawn Care <span class="text-green-800">Services</span>
        </h1>
        <p class="text-xl text-gray-500 leading-relaxed">
          Every service below is included on every single visit. No upsells, no add-on fees -
          just complete lawn care from start to finish.
        </p>
      </div>
    </section>

    <section class="py-16 sm:py-20 bg-white">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {services.map(({ title, slug, desc, icon }) => (
            <a
              href={`/services/${slug}`}
              class="fade-in group p-8 rounded-2xl bg-white border border-gray-100 shadow-sm hover:border-green-300 hover:shadow-md transition-all"
            >
              <div class="w-12 h-12 rounded-xl bg-green-100 flex items-center justify-center mb-4 group-hover:bg-green-200 transition-colors">
                <svg class="w-6 h-6 text-green-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon} />
                </svg>
              </div>
              <h2 class="text-xl font-extrabold text-gray-900 mb-2 group-hover:text-green-800 transition-colors">{title}</h2>
              <p class="text-gray-500 text-sm leading-relaxed mb-4">{desc}</p>
              <span class="inline-flex items-center gap-1 text-green-700 text-sm font-semibold">
                Learn more
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="py-14 bg-gradient-to-br from-green-600 to-emerald-700 text-white text-center">
      <div class="container mx-auto px-4 fade-in">
        <p class="text-white/80 text-lg font-medium mb-4">Ready to get started? Free quotes, always.</p>
        <a href="/#contact" class="inline-flex items-center justify-center gap-3 px-10 py-4 bg-white text-green-800 font-bold rounded-full hover:bg-green-50 transition-all shadow-2xl hover:scale-105 text-xl">
          Get a Free Quote
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
