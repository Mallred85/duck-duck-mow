---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import { getAllPosts, formatPostDate, getCategoryColor } from '@/lib/sanity';

const posts = await getAllPosts();
---

<BaseLayout
  title="Lawn Care Blog"
  description="Lawn care tips, seasonal guides, and weed control advice for homeowners in Herriman, Riverton, South Jordan & Bluffdale, Utah."
  keywords="lawn care tips Utah, mowing tips Herriman, spring lawn cleanup, weed control Riverton"
  breadcrumbs={[
    { name: 'Home', url: 'https://duckduckmow.com' },
    { name: 'Blog', url: 'https://duckduckmow.com/blog' },
  ]}
>
  <Nav currentPage="blog" />
  <main class="pt-16 lg:pt-20">

    <!-- Hero -->
    <section class="py-16 sm:py-20 bg-gradient-to-br from-green-50/60 via-white to-emerald-50/30">
      <div class="container mx-auto px-4 text-center fade-in">
        <span class="inline-block px-4 py-1.5 bg-green-50 text-green-800 text-sm font-semibold rounded-full mb-4">
          Lawn Care Tips
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 mb-4 font-display">
          The Duck Duck Mow <span class="text-green-800">Blog</span>
        </h1>
        <p class="text-lg text-gray-500 max-w-2xl mx-auto">
          Practical lawn care advice for homeowners in Herriman, Riverton, South Jordan & Bluffdale.
        </p>
      </div>
    </section>

    <!-- Posts grid -->
    <section class="py-16 sm:py-20 bg-white">
      <div class="container mx-auto px-4">
        {posts.length === 0 ? (
          <div class="text-center py-20 fade-in">
            <p class="text-gray-400 text-lg">No posts yet, check back soon!</p>
            <a href="/" class="mt-4 inline-flex items-center gap-2 text-green-800 font-semibold hover:underline">
              ← Back to Home
            </a>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {posts.map((post) => (
              <article class="fade-in group bg-white rounded-2xl border border-gray-100 hover:border-green-200 overflow-hidden hover:shadow-xl hover:shadow-green-500/5 transition-all hover:-translate-y-1">
                <div class="p-7">
                  <div class="flex items-center gap-3 mb-4">
                    <span class={`text-xs font-semibold px-3 py-1 rounded-full ${getCategoryColor(post.category)}`}>
                      {post.category}
                    </span>
                    <span class="text-xs text-gray-400">{post.readTime} min read</span>
                  </div>

                  <h2 class="text-lg font-extrabold text-gray-900 mb-3 group-hover:text-green-800 transition-colors leading-snug">
                    <a href={`/blog/${post.slug.current}`}>{post.title}</a>
                  </h2>

                  <p class="text-gray-500 text-sm leading-relaxed mb-5 line-clamp-3">{post.excerpt}</p>

                  <div class="flex items-center justify-between">
                    <div>
                      <p class="text-xs font-semibold text-gray-700">{post.author}</p>
                      <p class="text-xs text-gray-400">{formatPostDate(post.publishedAt)} · {post.city}</p>
                    </div>
                    <a
                      href={`/blog/${post.slug.current}`}
                      class="flex items-center gap-1 text-sm font-semibold text-green-800 hover:text-green-900 transition-colors"
                    >
                      Read
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-gradient-to-br from-green-600 to-emerald-700 text-white text-center">
      <div class="container mx-auto px-4 fade-in">
        <h2 class="text-2xl sm:text-3xl font-extrabold mb-4 font-display">Ready for a Great-Looking Lawn?</h2>
        <p class="text-white/80 mb-6">Free quotes for Herriman, Riverton, South Jordan & Bluffdale homeowners.</p>
        <a
          href="/#contact"
          class="inline-flex items-center gap-2 px-8 py-4 bg-white text-green-800 font-bold rounded-full hover:bg-green-50 transition-all shadow-xl hover:scale-105"
        >
          Get a Free Quote
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
