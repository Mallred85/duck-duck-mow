---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import QuoteForm from '@/components/QuoteForm.tsx';
import { forms } from '@/config/forms';
import { PHONE_DISPLAY, PHONE_HREF, site } from '@/config/site';

const city = 'Riverton';
const zip = '84065';
const slug = 'riverton-lawn-care';
const canonicalUrl = `${site.url}/${slug}`;

const localSchema = {
  '@type': ['LawnCareService', 'LocalBusiness'],
  '@id': `${site.url}/#business-riverton`,
  name: 'Duck Duck Mow',
  description: `Reliable lawn mowing, edging, trimming, and yard cleanup in Riverton, UT. Local family business serving Riverton homeowners with weekly and bi-monthly lawn care. Free quotes.`,
  url: canonicalUrl,
  telephone: site.business.telephone,
  email: site.business.email,
  address: {
    '@type': 'PostalAddress',
    addressLocality: city,
    addressRegion: 'UT',
    postalCode: zip,
    addressCountry: 'US',
  },
  areaServed: {
    '@type': 'City',
    name: city,
    containedInPlace: { '@type': 'State', name: 'Utah' },
  },
  priceRange: '$$',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Riverton Lawn Care Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Lawn Mowing Riverton UT' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Lawn Edging Riverton UT' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Yard Trimming Riverton UT' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Seasonal Cleanup Riverton UT' } },
    ],
  },
};

const faqs = [
  { q: 'What parts of Riverton do you serve?', a: 'We cover all of Riverton, including neighborhoods along the Mountain View Corridor, Redwood Road, and the areas bordering South Jordan and Herriman. If you\'re in the 84065 ZIP code, we\'ve got you covered.' },
  { q: 'Can you handle larger Riverton yards?', a: 'Absolutely. We quote based on your actual yard size, so larger properties get an accurate price — not a one-size-fits-all rate. Text us your address and we\'ll give you a fast, free estimate.' },
  { q: 'Do you work with Riverton HOAs?', a: 'Yes. Many of our Riverton customers have HOA requirements for lawn appearance and mowing frequency. We know what HOAs expect and our work consistently meets those standards.' },
  { q: 'How do I get started with lawn care in Riverton?', a: 'Fill out the quote form on this page or text us at 801-669-3819. We\'ll confirm your address, give you a price, and get you on the schedule — usually within the same week.' },
];
---

<BaseLayout
  title="Lawn Care Riverton UT | Mowing, Edging & Yard Service | Duck Duck Mow"
  noSuffix
  description="Dependable lawn mowing, edging, trimming, and seasonal cleanup in Riverton, Utah. Duck Duck Mow serves all Riverton neighborhoods. No contracts, free quotes, starting at $35/visit."
  keywords="lawn care Riverton UT, lawn mowing Riverton Utah, Riverton yard service, lawn service 84065, Riverton lawn company"
  canonical={canonicalUrl}
  breadcrumbs={[
    { name: 'Home', url: site.url },
    { name: 'Riverton Lawn Care', url: canonicalUrl },
  ]}
  schema={localSchema}
>
  <Nav />
  <main class="pt-16 lg:pt-20">

    <!-- Hero -->
    <section class="relative pt-16 pb-20 sm:pt-24 sm:pb-28 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-green-50/80 via-white to-emerald-50/40"></div>
      <div class="container mx-auto px-4 relative z-10 max-w-4xl">
        <div class="fade-in">
          <span class="inline-block px-4 py-1.5 bg-green-50 text-green-800 text-sm font-semibold rounded-full mb-4">
            Riverton, UT {zip}
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 mb-6 leading-tight font-display">
            Lawn Care in <span class="text-green-800">Riverton, Utah</span>
          </h1>
          <p class="text-xl text-gray-500 mb-4 max-w-2xl leading-relaxed">
            Riverton homeowners trust Duck Duck Mow for reliable, consistent lawn care all season long.
            We mow, edge, trim, and blow every visit — no shortcuts, no excuses.
          </p>
          <p class="text-gray-500 mb-8 max-w-2xl leading-relaxed">
            Whether your yard is a compact quarter-acre or a sprawling half-acre, we give it the same
            attention to detail. Prices start at $35 per visit with no contracts required.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="#quote" class="inline-flex items-center gap-2 px-8 py-4 bg-green-600 text-white font-bold rounded-full hover:bg-green-700 transition-all shadow-lg shadow-green-600/25 text-base">
              Get a Free Quote
            </a>
            <a href={PHONE_HREF} class="inline-flex items-center gap-2 px-8 py-4 bg-white text-green-800 font-bold rounded-full border-2 border-green-200 hover:border-green-400 transition-all text-base">
              Call {PHONE_DISPLAY}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Body Content -->
    <section class="py-16 sm:py-20 bg-white">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="fade-in mb-12">
          <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-4 font-display">
            Lawn Service Riverton <span class="text-green-800">Homeowners Rely On</span>
          </h2>
          <p class="text-lg text-gray-500 leading-relaxed mb-4">
            Riverton is one of the fastest-growing cities in Utah — which means more neighbors, higher
            HOA expectations, and less time to spend pushing a mower around on a hot Saturday afternoon.
          </p>
          <p class="text-gray-500 leading-relaxed mb-4">
            Duck Duck Mow fills that gap. We're a small, family-run operation based right here in South
            Salt Lake County. You won't get a different crew every week or a customer service line when
            something goes sideways. You get our personal cell number and the same brothers on your
            lawn every single visit.
          </p>
          <p class="text-gray-500 leading-relaxed">
            We service yards along the Mountain View Corridor, near Redwood Road, and throughout the
            neighborhoods that border South Jordan and Herriman. If you're in Riverton, we can help.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 fade-in">
          {[
            { label: 'Starting at $35', sub: 'Per visit, final price based on yard size' },
            { label: 'Weekly or Bi-Monthly', sub: 'You choose your schedule' },
            { label: 'HOA-Ready Results', sub: 'Consistent quality every time' },
          ].map(({ label, sub }) => (
            <div class="text-center p-6 rounded-2xl bg-green-50 border border-green-100">
              <p class="text-xl font-extrabold text-green-800 mb-1">{label}</p>
              <p class="text-sm text-gray-500">{sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="py-16 sm:py-20 bg-gradient-to-br from-green-50/40 to-white">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="text-center mb-12 fade-in">
          <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 font-display">
            Every Visit Includes
          </h2>
          <p class="text-gray-500 mt-3">Full-service lawn care on every single visit. Nothing left out.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {[
            { title: 'Lawn Mowing', desc: 'A clean, professional cut at the proper height for your Riverton grass type. We adjust based on season and growth rate.' },
            { title: 'Edging', desc: 'Sharp, defined edges along every driveway, sidewalk, and bed border. Riverton HOAs love it.' },
            { title: 'Trimming', desc: 'All the spots the mower misses — fence lines, around posts, sprinkler heads, retaining walls, and tight corners.' },
            { title: 'Blowing', desc: 'We blow all clippings off your driveway, sidewalk, and patio before we leave. Your yard will look showroom-ready.' },
          ].map(({ title, desc }) => (
            <div class="fade-in p-6 rounded-2xl bg-white border border-gray-100 shadow-sm hover:border-green-200 transition-colors">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-green-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-gray-900 mb-1">{title}</h3>
                  <p class="text-sm text-gray-500 leading-relaxed">{desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-16 sm:py-20 bg-white">
      <div class="container mx-auto px-4 max-w-3xl">
        <h2 class="text-2xl sm:text-3xl font-extrabold text-gray-900 text-center mb-10 font-display fade-in">
          Riverton Lawn Care <span class="text-green-800">FAQ</span>
        </h2>
        <div class="space-y-3">
          {faqs.map(({ q, a }) => (
            <div class="faq-item border border-gray-200 rounded-2xl overflow-hidden hover:border-green-200 transition-colors fade-in">
              <button class="faq-trigger w-full text-left px-6 py-5 flex items-center justify-between gap-4 font-semibold text-gray-900" aria-expanded="false">
                <span>{q}</span>
                <svg class="faq-icon w-5 h-5 text-green-800 flex-shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="text-gray-500 leading-relaxed text-sm">{a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Quote Form -->
    <section id="quote" class="py-20 sm:py-28 bg-gradient-to-b from-white to-green-50/30">
      <div class="container mx-auto px-4 max-w-3xl">
        <div class="text-center mb-12 fade-in">
          <span class="inline-block px-4 py-1.5 bg-green-50 text-green-800 text-sm font-semibold rounded-full mb-4">
            Free Quote — Riverton, UT
          </span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-3 font-display">
            Get Your <span class="text-green-800">Free Riverton Quote</span>
          </h2>
          <p class="text-gray-500 text-lg">Fill out the form and we'll respond same day.</p>
        </div>
        <div class="fade-in">
          <QuoteForm endpoint={forms.quoteEndpoint} client:load />
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="py-14 bg-gradient-to-br from-green-600 to-emerald-700 text-white text-center">
      <div class="container mx-auto px-4 fade-in">
        <p class="text-white/80 text-lg font-medium mb-4">Skip the Saturday mowing. Let us handle it.</p>
        <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-3 px-10 py-4 bg-white text-green-800 font-bold rounded-full hover:bg-green-50 transition-all shadow-2xl hover:scale-105 text-xl">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 8V5z" />
          </svg>
          Call or Text {PHONE_DISPLAY}
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  document.querySelectorAll('.faq-item').forEach((item) => {
    const trigger = item.querySelector('.faq-trigger')!;
    const answer  = item.querySelector('.faq-answer')!;
    const icon    = item.querySelector('.faq-icon')!;
    trigger.addEventListener('click', () => {
      const isOpen = !answer.classList.contains('hidden');
      answer.classList.toggle('hidden', isOpen);
      icon.classList.toggle('rotate-180', !isOpen);
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });
</script>
