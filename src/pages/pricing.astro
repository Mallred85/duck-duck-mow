---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import QuoteForm from '@/components/QuoteForm.tsx';
import { forms } from '@/config/forms';
import { PHONE_DISPLAY, PHONE_HREF } from '@/config/site';

const weeklyFeatures = [
  'Lawn mowing (clean, even cut)',
  'Edging along all borders',
  'Trimming around obstacles',
  'Blowing all hard surfaces',
  'Weekly visits during growing season',
  'Consistent crew, same brothers every time',
  'Free quote, no commitment',
];

const bimonthlyFeatures = [
  'Lawn mowing (clean, even cut)',
  'Edging along all borders',
  'Trimming around obstacles',
  'Blowing all hard surfaces',
  'Every-other-week visits',
  'Consistent crew, same brothers every time',
  'Free quote, no commitment',
];

const pricingFaqs = [
  { q: 'Why does the price start at $35 / $45?', a: 'The starting price covers a standard-sized yard. Larger yards take more time and effort, so we\'ll give you an exact quote after seeing your property. No surprises.' },
  { q: 'Is there a contract or commitment?', a: 'No contracts. We earn your business every visit. You can pause or stop service anytime, just give us a heads up.' },
  { q: 'When does the season run?', a: 'We typically run from April through September in the Salt Lake Valley, depending on weather. We\'ll keep you updated at the start and end of each season.' },
  { q: 'How do I pay?', a: 'We accept cash, Venmo, and other common payment methods. We\'ll confirm the best option for you when we set up your service.' },
  { q: 'Can I add a seasonal cleanup to my regular plan?', a: 'Absolutely! Just text or call us to schedule a cleanup in addition to your regular service. We\'ll give you a custom quote based on your yard.' },
];
---

<BaseLayout
  title="Pricing"
  description="Simple, transparent lawn care pricing starting at $35/visit. Weekly and bi-monthly mowing plans for Herriman, Riverton, South Jordan & Bluffdale, Utah."
  keywords="lawn mowing price Utah, lawn care cost Herriman, Riverton mowing price, affordable lawn service"
  breadcrumbs={[
    { name: 'Home', url: 'https://duckduckmow.com' },
    { name: 'Pricing', url: 'https://duckduckmow.com/pricing' },
  ]}
>
  <Nav currentPage="pricing" />
  <main class="pt-16 lg:pt-20">

    <!-- Hero -->
    <section class="relative pt-16 pb-20 sm:pt-20 sm:pb-28 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-green-50/80 via-white to-emerald-50/40"></div>
      <div class="container mx-auto px-4 relative z-10 text-center fade-in">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-green-50 text-green-800 text-sm font-semibold rounded-full mb-6">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          Simple, Transparent Pricing
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 mb-6 leading-tight font-display">
          Affordable Lawn Care <span class="text-green-800">You Can Count On</span>
        </h1>
        <p class="text-lg sm:text-xl text-gray-500 max-w-2xl mx-auto mb-3">
          No hidden fees. No surprises. Just a great-looking lawn every time.
        </p>
        <p class="text-sm text-gray-400">Serving Herriman, Riverton, South Jordan & Bluffdale, Utah</p>
      </div>
    </section>

    <!-- What's included bar -->
    <section class="py-12 bg-green-600 text-white">
      <div class="container mx-auto px-4">
        <p class="text-center text-xs font-semibold uppercase tracking-widest text-white/60 mb-8">
          Every visit includes
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto text-center">
          {[
            { label: 'Lawn Mowing', desc: 'Clean, even cut' },
            { label: 'Edging', desc: 'Crisp lines along all borders' },
            { label: 'Trimming', desc: 'Around obstacles & tight spots' },
            { label: 'Blowing', desc: 'All hard surfaces cleared' },
          ].map(({ label, desc }) => (
            <div>
              <p class="font-bold text-white text-sm">{label}</p>
              <p class="text-white/60 text-xs mt-1">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pricing cards -->
    <section class="py-20 sm:py-28">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16 fade-in">
          <span class="inline-block px-4 py-1.5 bg-green-50 text-green-800 text-sm font-semibold rounded-full mb-4">
            Packages
          </span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-gray-900 mb-4 font-display">
            Choose Your <span class="text-green-800">Schedule</span>
          </h2>
          <p class="text-lg text-gray-500 max-w-xl mx-auto">
            Both plans include our full service: mowing, edging, trimming, and blowing.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
          <!-- Weekly -->
          <div class="fade-in relative bg-white rounded-3xl border-2 border-green-600 shadow-2xl shadow-green-600/10 p-8 sm:p-10 flex flex-col">
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class="inline-flex items-center gap-1.5 px-5 py-1.5 bg-green-600 text-white text-xs font-bold rounded-full shadow-lg">
                <svg class="w-3.5 h-3.5 text-yellow-300" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                Most Popular
              </span>
            </div>
            <h3 class="text-xl font-extrabold text-gray-900 mt-2 mb-1">Weekly</h3>
            <p class="text-sm text-gray-500 mb-6">Every week, all season</p>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Starting at</p>
            <div class="flex items-end gap-2 mb-2">
              <span class="text-6xl font-extrabold text-green-800">$35</span>
              <span class="text-gray-400 mb-2 text-lg">/visit</span>
            </div>
            <p class="text-sm text-gray-400 mb-8">Final quote based on yard size</p>
            <ul class="space-y-3 mb-8 flex-1">
              {weeklyFeatures.map((item) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-800 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span class="text-sm text-gray-600">{item}</span>
                </li>
              ))}
            </ul>
            <a
              href="#quote"
              class="inline-flex items-center justify-center gap-2 w-full py-4 bg-green-600 text-white font-bold rounded-2xl hover:bg-green-700 transition-all shadow-lg shadow-green-600/25 text-base"
            >
              Get a Free Quote
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>

          <!-- Bi-Monthly -->
          <div class="fade-in bg-white rounded-3xl border-2 border-gray-200 p-8 sm:p-10 flex flex-col hover:border-green-200 transition-colors">
            <h3 class="text-xl font-extrabold text-gray-900 mb-1">Bi-Monthly</h3>
            <p class="text-sm text-gray-500 mb-6">Every two weeks</p>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Starting at</p>
            <div class="flex items-end gap-2 mb-2">
              <span class="text-6xl font-extrabold text-gray-900">$45</span>
              <span class="text-gray-400 mb-2 text-lg">/visit</span>
            </div>
            <p class="text-sm text-gray-400 mb-8">Final quote based on yard size</p>
            <ul class="space-y-3 mb-8 flex-1">
              {bimonthlyFeatures.map((item) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-800 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span class="text-sm text-gray-600">{item}</span>
                </li>
              ))}
            </ul>
            <a
              href="#quote"
              class="inline-flex items-center justify-center gap-2 w-full py-4 bg-gray-900 text-white font-bold rounded-2xl hover:bg-gray-800 transition-all text-base"
            >
              Get a Free Quote
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

        <p class="text-center text-sm text-gray-400 mt-8 max-w-xl mx-auto fade-in">
          Prices start at the listed rate. Final pricing is based on your yard size and confirmed in your free quote. No surprises.
        </p>
      </div>
    </section>

    <!-- Seasonal Cleanup Add-On -->
    <section class="py-16 sm:py-20 bg-gradient-to-br from-green-50/50 to-emerald-50/50">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto bg-white rounded-3xl border border-gray-100 shadow-lg overflow-hidden fade-in">
          <div class="grid grid-cols-1 md:grid-cols-2">
            <div class="p-8 sm:p-10">
              <span class="inline-block px-3 py-1 bg-amber-100 text-amber-700 text-xs font-bold rounded-full mb-4 uppercase tracking-wide">
                Add-On Service
              </span>
              <h3 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mb-3 font-display">
                Seasonal Cleanup
              </h3>
              <p class="text-gray-500 mb-6 leading-relaxed">
                Get your yard ready for the season with a thorough cleanup. Perfect for spring prep
                or fall leaf removal. We'll leave your yard looking its best.
              </p>
              <ul class="space-y-2 mb-8">
                {['Leaf removal & debris clearing', 'Edge cleanup & detail trimming', 'Full yard blowout', 'Spring & fall available'].map((item) => (
                  <li class="flex items-center gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-green-800 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
              <a
                href="#quote"
                class="inline-flex items-center gap-2 px-6 py-3 bg-green-600 text-white font-semibold rounded-full hover:bg-green-700 transition-all"
              >
                Request a Cleanup Quote
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
            <div class="bg-gradient-to-br from-green-600 to-emerald-700 p-8 sm:p-10 flex flex-col items-center justify-center text-white text-center">
              <p class="text-white/70 text-sm font-medium uppercase tracking-widest mb-2">Pricing</p>
              <p class="text-4xl font-extrabold mb-2">Custom Quote</p>
              <p class="text-white/70 text-sm max-w-xs">
                Every yard is different. Text or call us and we'll give you a fast, free estimate.
              </p>
              <a
                href={PHONE_HREF}
                class="mt-6 inline-flex items-center gap-2 px-6 py-3 bg-white/20 text-white font-semibold rounded-full border border-white/30 hover:bg-white/30 transition-all"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 8V5z"
                  />
                </svg>
                {PHONE_DISPLAY}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing FAQs -->
    <section class="py-16 sm:py-20 bg-white">
      <div class="container mx-auto px-4 max-w-3xl">
        <h2 class="text-2xl sm:text-3xl font-extrabold text-gray-900 text-center mb-10 font-display fade-in">
          Pricing <span class="text-green-800">FAQs</span>
        </h2>
        <div class="space-y-3">
          {pricingFaqs.map(({ q, a }) => (
            <div class="faq-item border border-gray-200 rounded-2xl overflow-hidden hover:border-green-200 transition-colors fade-in">
              <button class="faq-trigger w-full text-left px-6 py-5 flex items-center justify-between gap-4 font-semibold text-gray-900" aria-expanded="false">
                <span>{q}</span>
                <svg class="faq-icon w-5 h-5 text-green-800 flex-shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="text-gray-500 leading-relaxed text-sm">{a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Quote Form -->
    <section id="quote" class="py-20 sm:py-28 bg-gradient-to-b from-white to-green-50/30">
      <div class="container mx-auto px-4 max-w-3xl">
        <div class="text-center mb-12 fade-in">
          <span class="inline-block px-4 py-1.5 bg-green-50 text-green-800 text-sm font-semibold rounded-full mb-4">
            Free Quote
          </span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-3 font-display">
            Get Your <span class="text-green-800">Free Quote</span>
          </h2>
          <p class="text-gray-500 text-lg">Fill out the form and we'll get back to you same day.</p>
        </div>
        <div class="fade-in">
          <QuoteForm endpoint={forms.quoteEndpoint} showPlanSelector client:load />
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="py-14 bg-gradient-to-br from-green-600 to-emerald-700 text-white text-center">
      <div class="container mx-auto px-4 fade-in">
        <p class="text-white/80 text-lg font-medium mb-4">Prefer to talk? We're always available.</p>
        <a
          href={PHONE_HREF}
          class="inline-flex items-center justify-center gap-3 px-10 py-4 bg-white text-green-800 font-bold rounded-full hover:bg-green-50 transition-all shadow-2xl hover:scale-105 text-xl"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 8V5z"
            />
          </svg>
          Call or Text {PHONE_DISPLAY}
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  // Accordion for pricing FAQs
  document.querySelectorAll('.faq-item').forEach((item) => {
    const trigger = item.querySelector('.faq-trigger')!;
    const answer  = item.querySelector('.faq-answer')!;
    const icon    = item.querySelector('.faq-icon')!;
    trigger.addEventListener('click', () => {
      const isOpen = !answer.classList.contains('hidden');
      answer.classList.toggle('hidden', isOpen);
      icon.classList.toggle('rotate-180', !isOpen);
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });
</script>
