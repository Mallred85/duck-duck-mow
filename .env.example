# Sanity CMS
# Get from: sanity.io > your project > API
PUBLIC_SANITY_PROJECT_ID=lddbseu5
PUBLIC_SANITY_DATASET=production

# Quote form — Cloudflare Worker URL
# Set after deploying the worker in /worker
PUBLIC_QUOTE_FORM_ENDPOINT=https://ddm-quote-form.YOUR_ACCOUNT.workers.dev
